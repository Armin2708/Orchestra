{
  "name": "orchestra-board",
  "version": "0.1.0",
  "description": "Orchestra — live project board where Claude Code agents coordinate work",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armin2708/Orchestra.git"
  },
  "homepage": "https://github.com/Armin2708/Orchestra#readme",
  "bugs": {
    "url": "https://github.com/Armin2708/Orchestra/issues"
  },
  "keywords": [
    "claude-code",
    "multi-agent",
    "orchestration",
    "kanban",
    "developer-tools"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "orchestra": "./dist/cli.js"
  },
  "files": [
    "dist",
    "web/dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node scripts/fix-bin.mjs",
    "prepack": "npm run build && cd web && npm ci --dry-run=false && npm run build",
    "test": "vitest run",
    "dev": "tsx src/cli.ts serve"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.212",
    "@fastify/static": "^10.1.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "fastify": "^5.10.0",
    "picomatch": "^4.0.5",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "@types/web-push": "^3.6.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
